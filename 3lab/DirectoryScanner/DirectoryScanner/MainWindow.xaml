<Window x:Class="DirectoryScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DirectoryScanner"
        xmlns:lib="clr-namespace:ScannerLib;assembly=ScannerLib"
        mc:Ignorable="d"
        Title="Directory Scanner"
        Height="600"
        Width="800">
  <Window.Resources>
    <local:FolderToIconConverter x:Key="FolderToIconConverter" />
    <local:BooleanToStatusConverter x:Key="BooleanToStatusConverter" />
  </Window.Resources>
  <Window.DataContext>
    <local:MainViewModel/>
  </Window.DataContext>
  <DockPanel>
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Margin="8">
      <Button Content="Выбрать папку и сканировать"
              Padding="8,4"
              Margin="0,0,8,0"
              Command="{Binding StartCommand}"/>
      <Button Content="Отмена"
              Padding="8,4"
              Command="{Binding CancelCommand}"
              IsEnabled="{Binding IsScanning}"/>
      <TextBlock Margin="16,0,0,0"
                 VerticalAlignment="Center"
                 Text="{Binding IsScanning, Converter={StaticResource BooleanToStatusConverter}, FallbackValue=''}"/>
    </StackPanel>
    <TreeView ItemsSource="{Binding Root.Children}"
              Margin="8">
      <TreeView.Resources>
        <HierarchicalDataTemplate DataType="{x:Type lib:FileSystemNode}"
                                  ItemsSource="{Binding Children}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Width="20"
                       Text="{Binding IsFolder, Converter={StaticResource FolderToIconConverter}}"/>
            <TextBlock Margin="4,0,0,0"
                       Text="{Binding Name}"/>
            <TextBlock Margin="8,0,0,0"
                       Foreground="Gray">
              <Run Text="{Binding Size}"/>
              <Run Text=" байт"/>
              <Run Text=" ("/>
              <Run Text="{Binding Percentage, StringFormat={}{0:F1}}"/>
              <Run Text=" %)"/>
            </TextBlock>
          </StackPanel>
        </HierarchicalDataTemplate>
      </TreeView.Resources>
    </TreeView>
  </DockPanel>
</Window>

